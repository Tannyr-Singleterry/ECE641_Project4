//cam_capture.v
//ECE641 Project 4
//Camera frame capture module
//Waits for record_req (KEY[1] active-low), then on the next vsync
//captures one full 640x480 frame from the VGA output of CAMERA_D8M
//and streams it into the SDRAM write FIFOs in 512-word bursts.
//The write address base is set by bank_sel (SW[9:8]) mapping to
//the upper 2 bits of the 24-bit SDRAM address.
//
//Output interface is identical to the uart_mgr write interface so
//sdram_mgr can arbitrate between UART and camera writes without changes.

`timescale 1 ns / 1 ns

module cam_capture(ar, clk, record_req, bank_sel,
                   VGA_CLK, VGA_HS, VGA_VS, VGA_DE,
                   VGA_R, VGA_G, VGA_B,
                   cam_wr_addr_valid, cam_wr_addr,
                   cam_wr_data_valid, cam_wr_data);

    input ar;
    input clk;              // 148.5 MHz system clock (vpg_pclk)
    input record_req;       // ~KEY[1], active high
    input [1:0] bank_sel;   // SW[9:8], selects SDRAM bank 0-3

    // Camera VGA output (runs on VGA_CLK domain, ~25 MHz for 640x480)
    input VGA_CLK;
    input VGA_HS;
    input VGA_VS;
    input VGA_DE;
    input [7:0] VGA_R;
    input [7:0] VGA_G;
    input [7:0] VGA_B;

    // SDRAM write interface (same as uart_mgr outputs, to sdram_mgr)
    output reg cam_wr_addr_valid;
    output reg [23:0] cam_wr_addr;
    output reg cam_wr_data_valid;
    output reg [31:0] cam_wr_data;

    // ========================================================================
    // Parameters for 640x480 image
    // Each pixel = 3 bytes packed into a 32-bit word as {R, G, B, 8'h00}
    // Words per frame = 640 * 480 = 307200
    // Bursts per frame = 307200 / 512 = 600
    // Base address per bank = bank_sel * 24'h040000 (262144 words = 1MB)
    // ========================================================================

    parameter IMAGE_PIXELS   = 19'd307200;  // 640 * 480
    parameter WORDS_PER_BURST = 10'd512;
    parameter BURSTS_PER_FRAME = 10'd600;   // 307200 / 512

    // Bank base: bank 0=0x000000, 1=0x040000, 2=0x080000, 3=0x0C0000
    // Each bank is 0x040000 = 262144 words = 1 MB (well within 24-bit space)
    function [23:0] bank_base;
        input [1:0] bsel;
        begin
            bank_base = {bsel, 22'd0};
        end
    endfunction

    // ========================================================================
    // VGA_CLK domain: edge detect vsync and capture pixels into a small FIFO
    // ========================================================================

    // Synchronize record_req into VGA_CLK domain (2FF)
    reg record_req_s1_vga, record_req_s2_vga;
    always @(posedge VGA_CLK or posedge ar)
        if(~ar)
        begin
            record_req_s1_vga <= 1'b0;
            record_req_s2_vga <= 1'b0;
        end
        else
        begin
            record_req_s1_vga <= record_req;
            record_req_s2_vga <= record_req_s1_vga;
        end

    // Vsync edge detection in VGA_CLK domain
    reg vs_prev_vga;
    wire vs_posedge_vga;

    always @(posedge VGA_CLK or posedge ar)
        if(~ar)
            vs_prev_vga <= 1'b0;
        else
            vs_prev_vga <= VGA_VS;

    assign vs_posedge_vga = VGA_VS & ~vs_prev_vga;

    // Latch the record request until we see a vsync
    reg record_pending;

    always @(posedge VGA_CLK or posedge ar)
        if(~ar)
            record_pending <= 1'b0;
        else if(record_req_s2_vga)
            record_pending <= 1'b1;
        else if(vs_posedge_vga && record_pending)
            record_pending <= 1'b0;  // will start capture this frame

    // Capture FSM in VGA_CLK domain
    // Packs {R, G, B, 8'h00} into 32-bit words and pushes into capture FIFO
    reg capture_active;
    reg [31:0] pix_word;
    reg cap_wrreq;
    wire cap_wrfull;

    always @(posedge VGA_CLK or posedge ar)
        if(~ar)
        begin
            capture_active <= 1'b0;
            cap_wrreq      <= 1'b0;
            pix_word       <= 32'd0;
        end
        else
        begin
            cap_wrreq <= 1'b0;

            // Start capture on vsync if a record was requested
            if(vs_posedge_vga && record_pending)
                capture_active <= 1'b1;

            // On vsync at start of next frame, stop capture
            if(vs_posedge_vga && capture_active && !record_pending)
                capture_active <= 1'b0;

            // During active display, push each pixel as a 32-bit word
            if(capture_active && VGA_DE && !cap_wrfull)
            begin
                pix_word  <= {VGA_R, VGA_G, VGA_B, 8'h00};
                cap_wrreq <= 1'b1;
            end
        end

    // ========================================================================
    // Capture FIFO: bridges VGA_CLK (write) to vpg_pclk (read/system clock)
    // 1024 words deep, 32-bit wide
    // ========================================================================

    wire cap_rdempty;
    wire [10:0] cap_usedw;
    reg cap_rdreq;
    wire [31:0] cap_q;

    fifo_32_dc cap_fifo (
        .wrclk  (VGA_CLK),
        .rdclk  (clk),
        .aclr   (~ar),
        .wrreq  (cap_wrreq),
        .rdreq  (cap_rdreq),
        .data   (pix_word),
        .q      (cap_q),
        .wrempty(),
        .wrfull (cap_wrfull),
        .rdempty(cap_rdempty),
        .rdfull (),
        .usedw  (cap_usedw)
    );

    // ========================================================================
    // System clock (vpg_pclk) domain: drain cap_fifo in 512-word bursts
    // and issue sdram_mgr write interface signals
    // ========================================================================

    // Synchronize capture_active into system clock domain
    reg cap_active_s1, cap_active_s2;
    always @(posedge clk or posedge ar)
        if(~ar)
        begin
            cap_active_s1 <= 1'b0;
            cap_active_s2 <= 1'b0;
        end
        else
        begin
            cap_active_s1 <= capture_active;
            cap_active_s2 <= cap_active_s1;
        end

    // Capture drain FSM
    parameter [2:0] CAP_Idle      = 3'd0,
                    CAP_WaitFull  = 3'd1,
                    CAP_SendAddr  = 3'd2,
                    CAP_SendData  = 3'd3,
                    CAP_Done      = 3'd4;

    reg [2:0] cap_cs;
    reg [9:0] cap_burst_cnt;   // words sent in current burst
    reg [9:0] cap_burst_num;   // which burst (0 to BURSTS_PER_FRAME-1)
    reg [23:0] cap_base_addr;

    always @(posedge clk or posedge ar)
        if(~ar)
        begin
            cap_cs             <= CAP_Idle;
            cap_burst_cnt      <= 10'd0;
            cap_burst_num      <= 10'd0;
            cap_base_addr      <= 24'd0;
            cap_rdreq          <= 1'b0;
            cam_wr_addr_valid  <= 1'b0;
            cam_wr_addr        <= 24'd0;
            cam_wr_data_valid  <= 1'b0;
            cam_wr_data        <= 32'd0;
        end
        else
        begin
            cam_wr_addr_valid <= 1'b0;
            cam_wr_data_valid <= 1'b0;
            cap_rdreq         <= 1'b0;

            case(cap_cs)

                CAP_Idle:
                begin
                    // Wait until the VGA_CLK domain starts a capture
                    if(cap_active_s2)
                    begin
                        cap_base_addr <= bank_base(bank_sel);
                        cap_burst_num <= 10'd0;
                        cap_burst_cnt <= 10'd0;
                        cap_cs        <= CAP_WaitFull;
                    end
                end

                // Wait until capture FIFO has a full 512-word burst ready
                CAP_WaitFull:
                begin
                    if(!cap_active_s2 && cap_rdempty)
                    begin
                        // Capture ended and FIFO is drained - all done
                        cap_cs <= CAP_Done;
                    end
                    else if(cap_usedw >= 11'd512)
                    begin
                        // Issue the burst start address to sdram_mgr
                        cam_wr_addr       <= cap_base_addr;
                        cam_wr_addr_valid <= 1'b1;
                        cap_cs            <= CAP_SendAddr;
                    end
                end

                // Wait one cycle after asserting addr_valid then start data
                CAP_SendAddr:
                begin
                    cap_burst_cnt <= 10'd0;
                    cap_cs        <= CAP_SendData;
                end

                // Stream 512 words from the capture FIFO to sdram_mgr
                CAP_SendData:
                begin
                    if(!cap_rdempty)
                    begin
                        cam_wr_data       <= cap_q;
                        cam_wr_data_valid <= 1'b1;
                        cap_rdreq         <= 1'b1;

                        if(cap_burst_cnt < WORDS_PER_BURST - 1)
                            cap_burst_cnt <= cap_burst_cnt + 10'd1;
                        else
                        begin
                            // Burst complete - advance address for next burst
                            cap_burst_cnt <= 10'd0;
                            cap_base_addr <= cap_base_addr + 24'd512;
                            cap_burst_num <= cap_burst_num + 10'd1;

                            if(cap_burst_num < BURSTS_PER_FRAME - 1)
                                cap_cs <= CAP_WaitFull;
                            else
                                cap_cs <= CAP_Done;
                        end
                    end
                end

                // Frame fully written, wait for next record request
                CAP_Done:
                begin
                    if(!cap_active_s2)
                        cap_cs <= CAP_Idle;
                end

                default:
                    cap_cs <= CAP_Idle;

            endcase
        end

endmodule
