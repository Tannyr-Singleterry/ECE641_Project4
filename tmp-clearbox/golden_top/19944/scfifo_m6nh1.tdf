FUNCTION a_dpfifo_pofj (aclr, clock, data[23..0], rreq, sclr, wreq)
RETURNS ( empty, full, q[23..0], usedw[2..0]);

--synthesis_resources = altera_counter 2 lut 3 ram_bits (AUTO) 192 reg 5 
SUBDESIGN scfifo_m6nh1
( 
	aclr	:	input;
	clock	:	input;
	data[23..0]	:	input;
	empty	:	output;
	full	:	output;
	q[23..0]	:	output;
	rdreq	:	input;
	sclr	:	input;
	usedw[2..0]	:	output;
	wrreq	:	input;
) 
VARIABLE 
	dpfifo : a_dpfifo_pofj;

BEGIN 
	dpfifo.aclr = aclr;
	dpfifo.clock = clock;
	dpfifo.data[] = data[];
	dpfifo.rreq = rdreq;
	dpfifo.sclr = sclr;
	dpfifo.wreq = wrreq;
	empty = dpfifo.empty;
	full = dpfifo.full;
	q[] = dpfifo.q[];
	usedw[] = dpfifo.usedw[];
END;
