FUNCTION altera_syncram_impl_b0a91 (address_a[11..0], address_b[11..0], clock0, clock1, data_a[9..0], wren_a)
RETURNS ( q_b[9..0]);

--synthesis_resources = lut 5 ram_bits (AUTO) 40960 reg 2 
SUBDESIGN altera_syncram_p84d1
( 
	address_a[11..0]	:	input;
	address_b[11..0]	:	input;
	clock0	:	input;
	clock1	:	input;
	data_a[9..0]	:	input;
	q_b[9..0]	:	output;
	wren_a	:	input;
) 
VARIABLE 
	altera_syncram_impl1 : altera_syncram_impl_b0a91;

BEGIN 
	altera_syncram_impl1.address_a[] = address_a[];
	altera_syncram_impl1.address_b[] = address_b[];
	altera_syncram_impl1.clock0 = clock0;
	altera_syncram_impl1.clock1 = clock1;
	altera_syncram_impl1.data_a[] = data_a[];
	altera_syncram_impl1.wren_a = wren_a;
	q_b[] = altera_syncram_impl1.q_b[];
END;
